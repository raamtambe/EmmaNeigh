{
  "name": "emmaneigh",
  "version": "5.4.0",
  "description": "Transaction Management & Document Automation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "generate-icons": "npm install --no-save sharp png-to-ico && node generate-icons.js",
    "build:win": "electron-builder --win",
    "build:win:portable": "electron-builder --win portable",
    "build:mac": "electron-builder --mac"
  },
  "author": "Raam Tambe",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "archiver-utils": "^4.0.1",
    "electron-updater": "^6.1.7",
    "firebase": "^11.4.0",
    "nodemailer": "^6.9.8",
    "sql.js": "^1.10.0"
  },
  "build": {
    "appId": "com.emmaneigh.app",
    "productName": "EmmaNeigh",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!python/**",
      "!build/**",
      "!resources/**",
      "!dist/**",
      "!generate-icons.js",
      "!icon.svg",
      "!EmmaNeigh-Cleanup.ps1",
      "!*.ps1"
    ],
    "extraResources": [
      {
        "from": "resources/${os}",
        "to": "processor",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*.py"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "raamtambe",
      "repo": "EmmaNeigh"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "nsis": {
      "guid": "emmaneigh-transaction-app",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "EmmaNeigh-Setup.exe",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "uninstallDisplayName": "EmmaNeigh",
      "allowElevation": true,
      "license": "license.txt"
    }
  }
}
